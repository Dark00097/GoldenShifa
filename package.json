{
  "name": "goldenshifa",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "predev": "node scripts/free-dev-ports.mjs",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:raw --workspace server\" \"npm run dev:raw --workspace client\"",
    "dev:free-ports": "node scripts/free-dev-ports.mjs",
    "dev:reset": "node scripts/free-dev-ports.mjs --clean-next && npm run dev",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "start:client": "npm run start --workspace client",
    "start:server": "npm run start --workspace server"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
